# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files you want to normalize
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.config.ts text eol=lf
*.spec.ts text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary

